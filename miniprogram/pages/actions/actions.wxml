<!-- 行动建议 - actions.wxml -->
<view class="container page-content">
  <view class="module-intro">
    <view class="section-title">{{title}}</view>
    <view class="section-desc">{{intro}}</view>
  </view>
  <view class="card" wx:for="{{actions}}" wx:key="index">
    <view class="section-title" style="font-size:32rpx;">{{item.title}}</view>
    <view class="section-desc">{{item.desc}}</view>
  </view>
</view>
